theme = noctalia

font-family = FiraCode Nerd Font
font-size = 12.5

background-opacity = 0.9

cursor-style = block
cursor-style-blink = true

window-padding-x = 8
window-padding-y = 8

shell-integration = fish

copy-on-select = true

mouse-hide-while-typing = true

gtk-titlebar = false

confirm-close-surface = false
